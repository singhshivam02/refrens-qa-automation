{
  "name": "refrens-qa-automation",
  "version": "1.0.0",
  "description": "Playwright E2E tests for the Refrens public invoice generator",
  "bin": {
    "qa": "./scripts/qa.js"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:invoice": "playwright test tests/ui/invoice-en-in.spec.ts --headed",
    "test:report": "playwright show-report",
    "test:staging": "ENVIRONMENT=staging playwright test",
    "test:prod": "ENVIRONMENT=prod playwright test",
    "test:perf:staging": "ENVIRONMENT=staging playwright test tests/ui/invoice-performance.spec.ts",
    "test:perf:prod": "ENVIRONMENT=prod playwright test tests/ui/invoice-performance.spec.ts",
    "reports:stage": "ENV=stage node scripts/organize-reports.js",
    "reports:prod": "ENV=prod node scripts/organize-reports.js",
    "reports:compare": "node scripts/compare-reports.js",
    "perf:stage": "npm run test:perf:staging && npm run reports:stage",
    "perf:prod": "npm run test:perf:prod && npm run reports:prod",
    "perf:compare": "npm run perf:stage && npm run perf:prod && npm run reports:compare",
    "reports:notion": "node scripts/generate-notion-dashboard.js",
    "test:data:smoke": "playwright test tests/data/scenarios.smoke.spec.ts --headed --reporter=list",
    "qa": "ts-node scripts/create-data.ts",
    "qa:create": "ts-node scripts/create-data.ts",
    "qa:help": "ts-node scripts/create-data.ts help",
    "qa:use": "ts-node scripts/create-data.ts use",
    "qa:scenario": "ts-node scripts/create-data.ts scenario",
    "qa:invoice": "ts-node scripts/create-data.ts create invoice",
    "qa:setup": "npm install && npm link"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.43.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
