# ============================================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.
# ============================================================================

# Environment to run against: staging | production
ENVIRONMENT=staging

# Base URL — derived from ENVIRONMENT if omitted
# BASE_URL=https://qa01.bizsuggest.com

# Locale: en
LOCALE=en

# Browser headless mode
HEADLESS=true

# Element wait timeout in ms
TIMEOUT=30000

# How long (ms) to wait for manual CAPTCHA solving during auth setup
CAPTCHA_WAIT_MS=90000

# ── Refrens API Keys (required for data factories) ───────────────────────────
# Get from: Refrens app → Settings → API Keys
# These are used by the QA CLI and all factory functions.
API_APP_ID=your-app-id-here
API_APP_SECRET=your-app-secret-here

# API base URL — auto-derived from ENVIRONMENT if omitted:
#   staging    → https://serana.staging.bizsuggest.com
#   production → https://www.refrens.com
# API_BASE_URL=https://serana.staging.bizsuggest.com

# ── Default business (optional) ──────────────────────────────────────────────
# Set this to skip passing --urlKey on every CLI command.
# Alternatively run: qa use business <urlKey>
DEFAULT_URL_KEY=your-business-urlkey

# ── Credentials (UI browser tests only) ─────────────────────────────────────
# QA_EMAIL / QA_PASSWORD — used by auth.setup.ts to log in and save storageState.json.
# These are the Lydia (logged-in app) test credentials.
QA_EMAIL=your-email@example.com
QA_PASSWORD=your-password-here
TEST_PASSWORD=your-password-here
